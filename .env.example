# ImportIQ backend configuration. Copy to `.env` and fill in once you have
# credentials. `.env` is gitignored — never commit real secrets.

# Which data adapters to use:
#   mock      deterministic sample data (default, no credentials)
#   official  real mobile.de Search API (B2B/dealer creds; mobile.de only)
#   apify     live mobile.de + AutoScout24 + AutoUncle via Apify scrapers
DATA_SOURCE=mock

# --- mobile.de Search API (German listings) ---------------------------------
# Activate your account by emailing service@team.mobile.de, then set HTTP Basic
# credentials here. Required only when DATA_SOURCE=official.
MOBILEDE_USER=
MOBILEDE_PASS=
# Override the API base URL only if mobile.de tells you to.
# MOBILEDE_BASE_URL=https://services.mobile.de/search-api

# --- Apify scrapers (DATA_SOURCE=apify) -------------------------------------
# Live listings from mobile.de, AutoScout24 and AutoUncle. Get a token at
# https://console.apify.com (Settings → Integrations). Pay-as-you-go: you're
# billed per actor run / per result. Required only when DATA_SOURCE=apify.
APIFY_TOKEN=
# Which sites to query (comma-separated, in order).
# APIFY_SITES=mobilede,autoscout24,autouncle
# Max listings pulled per site per search.
# APIFY_MAX_PER_SITE=50
# Route scrapers through Apify Proxy to beat anti-bot (recommended).
# APIFY_USE_PROXY=true
# Cache identical searches this long (ms) to avoid re-paying (default 6h).
# APIFY_CACHE_TTL_MS=21600000
# Abort a single actor run after this long (ms).
# APIFY_RUN_TIMEOUT_MS=120000
#
# Override the Store actor used per site only if you prefer another:
# APIFY_MOBILEDE_ACTOR=3x1t/mobile-de-scraper
# APIFY_AUTOSCOUT24_ACTOR=automation-lab/autoscout24-scraper
# APIFY_AUTOUNCLE_ACTOR=lofomachines/autouncle-scraper
# AutoScout24 search country code (D=Germany, A=Austria, B=Belgium, …).
# APIFY_AUTOSCOUT24_COUNTRY=D
# AutoUncle locale: pair the domain with its localized list-path segment.
# APIFY_AUTOUNCLE_BASE_URL=https://www.autouncle.de
# APIFY_AUTOUNCLE_LIST_PATH=/de/gebrauchtwagen

# --- Portuguese market source -----------------------------------------------
# Which provider to query for PT market comparisons: `olx` or `standvirtual`.
# NOTE: read/search access for market comparison is provider-dependent and must
# be confirmed with the provider (see README "PT read-access caveat").
PT_PROVIDER=olx

# OLX Portugal Partner API
OLX_API_KEY=
# OLX_BASE_URL=https://api.olxgroup.com

# Standvirtual API (request read access via api@standvirtual.com)
STANDVIRTUAL_TOKEN=
# STANDVIRTUAL_BASE_URL=https://www.standvirtual.com/api

# PT market cache TTL in milliseconds (default 24h).
# PT_CACHE_TTL_MS=86400000
