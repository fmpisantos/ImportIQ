# --- Server runtime -------------------------------------------------------
PORT=8080

# German listing source: "mock" (default, offline) or "live" (AutoScout24).
SOURCE_MODE=mock
# Portuguese comparison source: "mock" (default) or "live" (Standvirtual + OLX).
PT_SOURCE_MODE=mock

# SQLite store location (default: server/data/importiq.db).
# DB_PATH=

# Polite delay (ms) between paged live-source requests.
SOURCE_PACING_MS=300

# --- Nightly batch scheduler (§9) — safe by default -----------------------
# The scheduler is DISABLED unless this is exactly "true".
SCHEDULER_ENABLED=false
SCHEDULER_CRON=0 3 * * *
BATCH_DEPTH_PAGES=5
BATCH_TOP_DEALS=20
