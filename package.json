{
  "name": "importiq",
  "version": "0.1.0",
  "private": true,
  "description": "Car import bot: search mobile.de, compute Portuguese landed cost, compare against the PT market.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "start": "npm run start --workspace server",
    "test": "npm run test --workspace server"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
